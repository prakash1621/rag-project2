# ============================================
# AWS Credentials (REQUIRED)
# ============================================
# Get these from AWS IAM Console
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ============================================
# AWS Bedrock Configuration
# ============================================
# Embedding Model (default: amazon.titan-embed-text-v1)
AWS_EMBEDDING_MODEL=amazon.titan-embed-text-v1

# LLM Model (default: anthropic.claude-3-haiku-20240307-v1:0)
AWS_LLM_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# ============================================
# Application Settings
# ============================================
# Cache backend: memory, sqlite, redis
CACHE_BACKEND=sqlite

# Cache directory (for SQLite backend)
CACHE_DIR=cache

# ============================================
# Optional: Redis Configuration
# ============================================
# Uncomment if using Redis cache backend
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================
# Optional: Vector Store Configuration
# ============================================
VECTOR_STORE_PATH=vector_store
KNOWLEDGE_BASE_PATH=knowledge-base

# ============================================
# Optional: Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=app.log

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. Never commit this file with real credentials
# 2. Copy this file to .env and fill in your values
# 3. Add .env to .gitignore
# 4. Ensure AWS credentials have Bedrock access permissions
